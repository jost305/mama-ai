{
  "project_name": "OjaLM-1",
  "base_model": {
    "hf_hub_id": "unsloth/Qwen2.5-1.5B-Instruct",
    "architecture": "qwen2",
    "quantization": "4bit"
  },
  "dataset": {
    "format": "sharegpt",
    "chat_template": "chatml",
    "local_path": "training_corpus.jsonl"
  },
  "lora_parameters": {
    "r": 16,
    "lora_alpha": 16,
    "lora_dropout": 0,
    "bias": "none",
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ]
  },
  "training_hyperparameters": {
    "per_device_train_batch_size": 2,
    "gradient_accumulation_steps": 4,
    "warmup_steps": 5,
    "max_steps": 60,
    "learning_rate": 0.0002,
    "lr_scheduler_type": "linear",
    "optim": "adamw_8bit",
    "weight_decay": 0.01,
    "seed": 3407
  },
  "export": {
    "merge_adapters": true,
    "format": "gguf"
  }
}
